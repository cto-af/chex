{
  "name": "@cto.af/chex-monorepo",
  "version": "2.2.3",
  "description": "hexdump -C as a small JS library",
  "private": "true",
  "type": "module",
  "workspaces": [
    "./pkg/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cto-af/chex.git"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "c8 ava",
    "snaps": "c8 ava --update-snapshots",
    "build": "pnpm --filter '@cto.af/*' --if-present -r build",
    "version": "monopub version && pnpm run --sequential --if-present -r version && pnpm i -r && git add pnpm-lock.yaml",
    "ci": "npm run build && npm run lint && npm run test"
  },
  "keywords": [
    "hexdump",
    "hex",
    "unicode"
  ],
  "author": "Joe Hildebrand <joe-github@cursive.net>",
  "license": "MIT",
  "devDependencies": {
    "@cto.af/eslint-config": "^6.2.5",
    "@cto.af/monopub": "^1.2.4",
    "@types/node": "^25.5.0",
    "ava": "^7.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-ava": "^16.0.0",
    "superc8": "^12.3.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  }
}
